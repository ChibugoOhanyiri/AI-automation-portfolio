    {
      "parameters": {
        "resource": "mail",
        "fromEmail": "noreply@yourdomain.com",
        "fromName": "=company",
        "toEmail": "={{ $json.borrower_email }}",
        "subject": "We got your loan request!",
        "contentType": "text/html",
        "contentValue": "=<html>\n\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Document</title>\n  <link href=\"https://fonts.googleapis.com/css?family=Work+Sans:400,500,600,700,800,900&display=swap\"\n    rel=\"stylesheet\" />\n  <style>\n    html,\n    body {\n      margin: 0;\n      padding: 0;\n    }\n\n    table {\n      border: 0;\n      border-spacing: 0;\n      border-collapse: collapse;\n    }\n\n    @media screen and (max-width: 520px) {\n      h1.header {\n        font-size: 24px !important;\n        line-height: 24px !important;\n      }\n    }\n  </style>\n</head>\n\n<body width=\"100%\" style=\"width: 100%; background: #eaeaea\" bgcolor=\"#F1F3F5\">\n  <center>\n    <table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\"\n      style=\"width: 95%; max-width: 600px\">\n      <tr>\n        <td class=\"email-container\">\n          <table cellpadding=\"0\" cellspacing=\"0\" role=\"presentation\" style=\"width: 100%; margin: 50px auto\">\n            <!--- Logo: START -->\n            <tr>\n              <td style=\"padding: 20px\">\n                <a href=\"#\">\n                  <img\n                      src=\"https://lsq.li/lendsqr-long-logo\"\n                      border=\"0\"\n                      height=\"30\"\n                      style=\"display: block\"\n                    />\n                </a>\n              </td>\n            </tr>\n            <!--- Logo: END -->\n            <!--- Header: START -->\n            <tr>\n              <td>\n\n              </td>\n            </tr>\n            <!--- Header: END -->\n\n            <!--- Body: START -->\n            <tr>\n              <td style=\"\n                    font-family: Inter, Arial, sans-serif;\n                    font-size: 16px;\n                    line-height: 150%;\n                    color: rgb(45, 46, 46);\n                    background-color: #fff;\n                    border-radius: 10px 10px 0 0;\n                    padding: 50px 50px;\n                  \">\n\n\n                <h2 style=\"\n                      font-size: 35px;\n                      font-family: Degular Display, Arial, sans-serif;\n                      line-height: 110%;\n                    \">\n                  We got your loan request!\n                </h2>\n\n                <p><b>Hi {{ $json.borrower_name }}, </b></p>\n\n                <p>\n                  Thanks for using our lender directory to apply for a loan!\n                  We've received your loan request and sent it to {{ $json.org_name }}. They'll review your application and\n                  reach out to you directly.\n                </p>\n\n                <h3>\n                  Here's what you applied for:\n                </h3>\n\n                <p>\n                <ul>\n                  <li>Amount: {{ $json['Loan amount'] }}</li>\n                  <li>Purpose: {{ $json.Purpose }}</li>\n                  <li>Tenor: {{ $json.Tenor }}</li>\n                </ul>\n                </p>\n\n                <h3>What happens next?</h3>\n\n                <p> {{ $json.org_name }} will contact you via phone or email. Response times vary by lender, but most get back\n                  quickly.</p>\n                <h3>Other lenders you can try:</h3>\n                <p>While you wait, you can also reach out to these verified lenders:<br />\n                <ul>\n                  <li><a href='https://lendsqr.com/lenders'>Irorun</a><br /></li>\n                  <li><a href='https://lendsqr.com/lenders'>BlockaCash</a><br /></li>\n                  <li><a href='https://lendsqr.com/lenders'>Urgent10k</a><br /></li>\n                  <li><a href='https://lendsqr.com/lenders'>SnapCash</a><br /></li>\n                  <li><a href='https://lendsqr.com/lenders'>OgaCash</a></li>\n                </ul>\n                </p>\n                <h3>Some helpful reads while you wait:</h3>\n                <p>\n                <ul>\n                  <li><a href='https://blog.lendsqr.com/7-top-loan-apps-for-iphone-users-in-nigeria/'>7 top loan apps\n                      for iPhone users in Nigeria</a><br /></li>\n                  <li><a href='https://blog.lendsqr.com/where-to-get-loans-with-low-interest-rates-in-nigeria/'>Where to\n                      get loans with low interest rates in Nigeria</a><br /></li>\n                  <li><a href='5 best loan apps in Nigeria with low interest '>5 best loan apps in Nigeria with low\n                      interest</a><br /></li>\n                  <li><a\n                      href='https://blog.lendsqr.com/why-gig-workers-are-denied-loans-and-how-better-credit-scoring-helps/'>Why\n                      gig workers are denied loans, and how better credit scoring helps</a><br /></li>\n                </ul>\n                If you submitted this by mistake or changed your mind, just reply and let us know.\n                </p>\n                <p>Thanks for trusting us!</p>\n              </td>\n            </tr>\n            <!--- Body: END -->\n\n            <!--- Footer: START -->\n            <tr>\n              <td style=\"\n                    font-family: 'Inter', sans-serif;\n                    font-size: 12px;\n                    line-height: 22px;\n                    color: #334a6a;\n                    opacity: 0.6;\n                    padding: 50px;\n                    padding-top: 20px;\n                    /* border-top: 1px solid rgba(17, 41, 69, 0.1); */\n                    border-radius: 0 0 10px 10px;\n                    background-color: #fff;\n                  \">\n                <p style=\"margin: 0; width: 100%\">\n                  We genuinely care about you, so if there's\n                  anything at all we can do to help, please reach out to us\n                  via email at\n                  <a href=\"mailto:support@lendsqr.com\">support@lendsqr.com</a>.\n                </p>\n\n              </td>\n            </tr>\n            <!--- Footer: END -->\n          </table>\n        </td>\n      </tr>\n    </table>\n  </center>\n</body>\n\n</html>",
        "additionalFields": {}
      },
